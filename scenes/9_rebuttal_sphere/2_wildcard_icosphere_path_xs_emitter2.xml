    <!-- Camera. This version looks at the center of the hemisphere from inside -->
    <sensor type="orthographic">
        <string name="fov_axis" value="x"/>
        <float name="fov" value="40"/>
        <transform name="toWorld">
            <lookAt origin="0, 0, 0.1" target="0, 0, 0" up="0, 1, 0"/>
        </transform>
        <sampler type="independent">
            <integer name="sample_count" value="64"/>
        </sampler>
        <film type="hdrfilm">
            <integer name="width" value="64"/>
            <integer name="height" value="64"/>
        </film>
    </sensor> 

    <!-- Spotlight at center, slightly above floor, pointing up, near-180° cone -->
