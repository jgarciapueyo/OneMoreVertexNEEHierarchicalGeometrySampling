<?xml version="1.0" encoding="utf-8"?>
<!--
Note: this file has many wildcards so that it can be used from the scripts/experiments/ script.

Now you dont need to give values to all wildcards, since we support default values as: "$value:3"

OLD: To run it directly you must give values to all wildcards, e.g.:
	./build/release/mitsuba/mitsuba scenes/experiments/3_wildcard_disney/wildcard_disney_quads.xml -Dintegrator=doublestep -DmaxDepth=3 -DrrDepth=4 -DuseBVH=true -DdisableNEE=false -DmaxLeafSize=2 -DleafSamplingMode=SphericalAABB -DoutputDebugCSV=false -DenableSpecular=1 -Dgeometry=quads-disney-rough0.3-k40.xml -Dspp=512
 -->
<scene version="0.6.0">
	<integrator type="$integrator:doublestep">
		<integer name="maxDepth" value="$maxDepth:3"/>
		<integer name="rrDepth" value="$rrDepth:5"/>
		<boolean name="useBVH" value="$useBVH:true"/>
		<boolean name="disableNEE" value="$disableNEE:false"/>
	</integrator>
	<geometrybvh type="geometrybvh">
		<!-- Note: Now the geometrybvh is a separate plugin, so it can have its own props here: -->
		
		<!-- <integer name="maxLeafSize" value="$maxLeafSize:1"/> -->
		<!--  ^disabled in favor of maxDepth:-->
		<integer name="maxDepth" value="$bvhMaxDepth:8"/>
		<string name="samplingMode" value="$leafSamplingMode:SphericalAABB"/>
		<!-- Valid values: Primitive, SphericalAABB -->
		<boolean name="outputDebugCSV" value="$outputDebugCSV:false"/>
		<boolean name="enableLightcuts" value="$enableLightcuts:false"/>
		<float name="lightcutThreshold" value="$lightcutThreshold:0"/>

		<float name="gaussianSAThreshold" value="$gaussianSAThreshold:0.031"/>
		<float name="debug1" value="$useUniformBVHSampling:1"/>
		<!-- ^debug prop to have an equal importance mode for testing (if <= .0001f, then importance is set to 1 for all nodes) -->
		<float name="debug2" value="$enableSpecular:1"/>
		<!-- ^0: diffuse-only importance; 1: specular-aware importance (computeNodeImportance_Unscented_LUT_Specular) -->
		<float name="debug3" value="$enableFastLUT:0"/>
		<float name="defensivePDF" value="$defensivePDF:0.000001"/>
		<!-- ABLATION SETTINGS 
            enableAblation("ablateVMF", AblateVMF);
			enableAblation("ablateGaussian", AblateGaussian);
			enableAblation("ablateCosineXs", AblateCosineXs);
			enableAblation("ablateCosineXe", AblateCosineXe);
			enableAblation("ablateDistanceXs", AblateDistanceXs);
			enableAblation("ablateDistanceXe", AblateDistanceXe);
			enableAblation("ablateAlbedo", AblateAlbedo);
		-->
		<boolean name="ablateVMF" value="$ablateVMF:false"/>
		<boolean name="ablateGaussian" value="$ablateGaussian:false"/>
		<boolean name="ablateCosineXs" value="$ablateCosineXs:false"/>
		<boolean name="ablateCosineXe" value="$ablateCosineXe:false"/>
		<boolean name="ablateDistanceXs" value="$ablateDistanceXs:false"/>
		<boolean name="ablateDistanceXe" value="$ablateDistanceXe:false"/>	
		<boolean name="ablateAlbedo" value="$ablateAlbedo:false"/>		


	</geometrybvh>
	<sensor type="perspective">
		<string name="fovAxis" value="smaller"/>
		<float name="nearClip" value="0.0001"/>
		<float name="farClip" value="1000"/>
		<transform name="toWorld">
			<lookAt origin="-11, 0, 3" target="0, 0, 0.5" up="0, 0, 1"/>
		</transform>
		<float name="fov" value="30"/>
		<sampler type="independent">
			<integer name="sampleCount" value="$spp:16"/>
		</sampler>
		<film type="hdrfilm">
			<integer name="width" value="256"/>
			<integer name="height" value="256"/>
		</film>
	</sensor>
	<emitter type="spot" name="spot_light">
		<transform name="toWorld">
			<rotate x="0" y="1" z="0" angle="60"/>
			<translate x="-5" y="0" z="1"/>
		</transform>
		<rgb name="intensity" value="10000"/>
		<float name="cutoffAngle" value="30"/>
	</emitter>
	<shape type="rectangle">
		<transform name="toWorld">
			<scale x="10" y="10" z="1"/>
			<translate x="0" y="0" z="0"/>
		</transform>
		<bsdf type="diffuse">
			<texture type="checkerboard" name="reflectance">
				<float name="uscale" value="50"/>
				<float name="vscale" value="50"/>
			</texture>
		</bsdf>
	</shape>
	<!-- veach slabs of icreasing roughness: -->
	<shape type="rectangle">
        <transform name="toWorld">
            <scale x=".32" y="1.2" z=".1"/>
            <translate x="-4" y="0" z="0"/>
        </transform>
        <bsdf type="roughconductor">
            <string name="material" value="Ag"/>
            <string name="distribution" value="ggx"/>
            <float name="alpha" value="0.02"/>
        </bsdf>
    </shape>

    <shape type="rectangle">
        <transform name="toWorld">
            <scale x=".32" y="1.2" z=".1"/>
            <translate x="-3" y="0" z="0"/>
        </transform>
        <bsdf type="roughconductor">
            <string name="material" value="Ag"/>
            <string name="distribution" value="ggx"/>
            <float name="alpha" value="0.1"/>
        </bsdf>
    </shape>

    <shape type="rectangle">
        <transform name="toWorld">
            <scale x=".32" y="1.2" z=".1"/>
            <translate x="-2" y="0" z="0"/>
        </transform>
        <bsdf type="roughconductor">
            <string name="material" value="Ag"/>
            <string name="distribution" value="ggx"/>
            <float name="alpha" value="0.3"/>
        </bsdf>
    </shape>

    <shape type="rectangle">
        <transform name="toWorld">
            <scale x=".32" y="1.2" z=".1"/>
            <translate x="-1." y="0" z="0"/>
        </transform>
        <bsdf type="roughconductor">
            <string name="material" value="Ag"/>
            <string name="distribution" value="ggx"/>
            <float name="alpha" value="0.6"/>
        </bsdf>
    </shape>
	<!-- Geometry: principled-BSDF quads. The .xml extension must be included in the param value. -->
	<include filename="../scene_geometries/$geometry:quads-k5.xml"/>
</scene>
