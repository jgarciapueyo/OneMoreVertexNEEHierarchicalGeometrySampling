<?xml version="1.0" encoding="utf-8"?>
<!-- High-SPP path tracer reference for the Disney BSDF experiment.
     ./build/release/mitsuba/mitsuba scenes/experiments/3_wildcard_disney/wildcard_disney_quads_pathref.xml -Dgeometry=quads-disney-rough0.3-k40.xml -Dspp=8192 -->

<scene version="0.6.0">
	<integrator type="$integrator:path">
		<integer name="maxDepth" value="3"/>
		<integer name="rrDepth" value="5"/>
	</integrator>
	<sensor type="perspective">
		<string name="fovAxis" value="smaller"/>
		<float name="nearClip" value="0.0001"/>
		<float name="farClip" value="1000"/>
		<transform name="toWorld">
			<lookAt origin="-5, 0, 3" target="0, 0, 1" up="0, 0, 1"/>
		</transform>
		<float name="fov" value="45"/>
		<sampler type="independent">
			<integer name="sampleCount" value="$spp"/>
		</sampler>
		<film type="hdrfilm">
			<integer name="width" value="256"/>
			<integer name="height" value="256"/>
		</film>
	</sensor>
	<emitter type="spot" name="spot_light">
		<transform name="toWorld">
			<rotate x="0" y="1" z="0" angle="60"/>
			<translate x="-5" y="0" z="1"/>
		</transform>
		<rgb name="intensity" value="10000"/>
		<float name="cutoffAngle" value="30"/>
	</emitter>
	<shape type="rectangle">
		<transform name="toWorld">
			<scale x="10" y="10" z="1"/>
			<translate x="0" y="0" z="0"/>
		</transform>
		<bsdf type="diffuse">
			<texture type="checkerboard" name="reflectance">
				<float name="uscale" value="50"/>
				<float name="vscale" value="50"/>
			</texture>
		</bsdf>
	</shape>
	<!-- The .xml extension must be included in the param value. -->
	<include filename="../scene_geometries/$geometry:quads-disney-rough0.3-k40.xml"/>
</scene>
